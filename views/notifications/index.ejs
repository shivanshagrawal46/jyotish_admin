<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notifications | Admin Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet">
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/sidebar.css" rel="stylesheet">
    <style>
        :root {
            --primary: #2D3250; --secondary: #424769; --accent: #676F9D;
            --orange: #FF6B35; --light: #F4F6FB; --dark: #1A1B26;
            --card-shadow: 0 4px 24px rgba(45,50,80,.10);
        }
        body { font-family: 'Inter', sans-serif; background: var(--light); min-height: 100vh; }
        .main-content { margin-left: 280px; padding: 2rem; }

        .topbar {
            background: white; padding: 1rem 2rem; border-radius: 16px;
            box-shadow: var(--card-shadow); margin-bottom: 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
        }
        .page-title { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--dark); margin: 0; }

        .add-btn {
            background: linear-gradient(135deg, #FF6B35, #F7931E); color: white; border: none;
            border-radius: 12px; padding: .65rem 1.5rem; font-weight: 700;
            text-decoration: none; display: inline-flex; align-items: center; gap: .5rem;
            transition: all .2s; font-size: .95rem;
        }
        .add-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,107,53,.35); color: white; }

        /* ── Stats row ─────────────────────────────────────── */
        .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
        .stat-card {
            background: white; border-radius: 14px; padding: 1.25rem; box-shadow: var(--card-shadow);
            display: flex; align-items: center; gap: 1rem;
        }
        .stat-icon {
            width: 48px; height: 48px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
            flex-shrink: 0;
        }
        .stat-icon.blue   { background: rgba(33,150,243,.12); }
        .stat-icon.orange { background: rgba(255,107,53,.12); }
        .stat-icon.green  { background: rgba(34,197,94,.12); }
        .stat-icon.purple { background: rgba(156,39,176,.12); }
        .stat-num  { font-size: 1.6rem; font-weight: 700; color: var(--dark); line-height: 1; }
        .stat-label{ font-size: .78rem; color: #9CA3AF; font-weight: 500; margin-top: .2rem; }

        /* ── Filter bar ────────────────────────────────────── */
        .filter-bar {
            background: white; border-radius: 14px; padding: 1rem 1.5rem;
            box-shadow: var(--card-shadow); margin-bottom: 1.5rem;
            display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
        }
        .filter-label { font-weight: 600; font-size: .85rem; color: var(--secondary); white-space: nowrap; }
        .filter-chips { display: flex; gap: .5rem; flex-wrap: wrap; }
        .chip {
            border: 1.5px solid var(--border, #E2E8F0); border-radius: 20px;
            padding: .3rem .85rem; font-size: .78rem; font-weight: 600; cursor: pointer;
            text-decoration: none; color: var(--secondary); transition: all .2s; background: white;
            display: inline-flex; align-items: center; gap: .35rem;
        }
        .chip:hover { border-color: var(--orange); color: var(--orange); background: rgba(255,107,53,.04); }
        .chip.active { background: var(--orange); color: white; border-color: var(--orange); }

        /* ── List ──────────────────────────────────────────── */
        .notif-card {
            background: white; border-radius: 16px; box-shadow: var(--card-shadow);
            margin-bottom: 1rem; overflow: hidden; transition: box-shadow .2s;
        }
        .notif-card:hover { box-shadow: 0 8px 32px rgba(45,50,80,.14); }

        .notif-card-inner { display: flex; }
        .notif-accent-bar {
            width: 5px; flex-shrink: 0;
            background: linear-gradient(180deg, var(--orange), #F7931E);
        }
        .notif-accent-bar.info    { background: #2196F3; }
        .notif-accent-bar.success { background: #22C55E; }
        .notif-accent-bar.warning { background: #FF9800; }
        .notif-accent-bar.error   { background: #EF4444; }
        .notif-accent-bar.announcement { background: #9C27B0; }
        .notif-accent-bar.content { background: linear-gradient(180deg, #FF6B35, #F7931E); }

        .notif-body { flex: 1; padding: 1.25rem 1.5rem; }
        .notif-top { display: flex; align-items: flex-start; gap: .75rem; flex-wrap: wrap; }
        .notif-title { font-weight: 700; font-size: 1rem; color: var(--dark); flex: 1; min-width: 180px; }
        .notif-message { color: #6B7280; margin: .4rem 0 .75rem; line-height: 1.6; font-size: .9rem; }

        .badge-pill {
            display: inline-flex; align-items: center; gap: .3rem;
            border-radius: 20px; padding: .2rem .65rem; font-size: .72rem; font-weight: 700;
        }
        .badge-type  { background: rgba(33,150,243,.1);  color: #2196F3; }
        .badge-type.success { background: rgba(34,197,94,.1); color: #16A34A; }
        .badge-type.warning { background: rgba(255,152,0,.1); color: #F59E0B; }
        .badge-type.error   { background: rgba(239,68,68,.1); color: #EF4444; }
        .badge-type.announcement { background: rgba(156,39,176,.1); color: #9C27B0; }
        .badge-type.content { background: rgba(255,107,53,.1); color: var(--orange); }
        .badge-priority { background: rgba(45,50,80,.08); color: var(--secondary); }
        .badge-priority.urgent { background: rgba(239,68,68,.1); color: #EF4444; }
        .badge-priority.high   { background: rgba(255,152,0,.1); color: #F59E0B; }
        .badge-active   { background: rgba(34,197,94,.1);  color: #16A34A; }
        .badge-inactive { background: rgba(156,163,175,.1); color: #9CA3AF; }

        .deeplink-row {
            display: flex; align-items: center; gap: .5rem; flex-wrap: wrap;
            background: rgba(255,107,53,.04); border: 1px solid rgba(255,107,53,.15);
            border-radius: 8px; padding: .5rem .75rem; margin: .5rem 0;
        }
        .deeplink-section-badge {
            background: var(--orange); color: white; border-radius: 6px;
            padding: .15rem .5rem; font-size: .68rem; font-weight: 700; text-transform: uppercase;
        }
        .deeplink-title { font-size: .8rem; font-weight: 600; color: var(--dark); }
        .deeplink-url   { font-size: .7rem; color: #9CA3AF; font-family: monospace; word-break: break-all; }

        .notif-meta {
            display: flex; align-items: center; justify-content: space-between;
            flex-wrap: wrap; gap: .5rem; margin-top: .75rem;
        }
        .meta-dates { font-size: .75rem; color: #9CA3AF; display: flex; gap: 1rem; flex-wrap: wrap; }

        .analytics-row {
            display: flex; gap: 1.25rem; font-size: .78rem; color: #9CA3AF; align-items: center;
        }
        .analytics-row .val { font-weight: 700; color: var(--dark); }

        .action-row { display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; }
        .btn-action {
            border-radius: 8px; padding: .35rem .85rem; font-size: .78rem; font-weight: 600;
            border: 1.5px solid; cursor: pointer; text-decoration: none; transition: all .15s;
            display: inline-flex; align-items: center; gap: .3rem;
        }
        .btn-edit   { border-color: var(--accent);  color: var(--accent);  background: white; }
        .btn-edit:hover { background: var(--accent); color: white; }
        .btn-resend { border-color: var(--orange);  color: var(--orange);  background: white; }
        .btn-resend:hover { background: var(--orange); color: white; }
        .btn-del    { border-color: #EF4444; color: #EF4444; background: white; }
        .btn-del:hover { background: #EF4444; color: white; }
        .btn-toggle { border-color: #D1D5DB; color: #6B7280; background: white; }
        .btn-toggle:hover { background: #F3F4F6; }

        /* ── Pagination ─────────────────────────────────────── */
        .pager { display: flex; gap: .5rem; justify-content: center; margin-top: 1.5rem; }
        .page-btn {
            width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center;
            justify-content: center; font-size: .85rem; font-weight: 600; text-decoration: none;
            border: 1.5px solid var(--border, #E2E8F0); color: var(--secondary); background: white;
            transition: all .15s;
        }
        .page-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
        .page-btn:hover:not(.active) { border-color: var(--accent); color: var(--accent); }

        /* ── Empty ──────────────────────────────────────────── */
        .empty-state { text-align: center; padding: 4rem 2rem; }
        .empty-state .big-icon { font-size: 4rem; opacity: .4; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <nav class="sidebar">
        <%- include('../partials/sidebar', {
            activePage: 'notifications', username,
            activeCategory: null, activeSubCategory: null,
            koshCategories: [], mcqCategories: []
        }) %>
    </nav>

    <main class="main-content">
        <!-- Topbar -->
        <div class="topbar">
            <h1 class="page-title">🔔 Notifications</h1>
            <a href="/notifications/add" class="add-btn">
                ＋ Send Notification
            </a>
        </div>

        <!-- Alerts -->
        <% if (success) { %>
            <div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:12px;padding:.9rem 1.25rem;margin-bottom:1.25rem;color:#166534;font-weight:600">
                ✅ <%= success %>
            </div>
        <% } %>
        <% if (error) { %>
            <div style="background:#FEF2F2;border:1px solid #FECACA;border-radius:12px;padding:.9rem 1.25rem;margin-bottom:1.25rem;color:#DC2626;font-weight:600">
                ⚠️ <%= error %>
            </div>
        <% } %>

        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon blue">🔔</div>
                <div>
                    <div class="stat-num"><%= total %></div>
                    <div class="stat-label">Total Notifications</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon orange">🔗</div>
                <div>
                    <div class="stat-num"><%= notifications.filter(n => n.deepLink && n.deepLink.contentType).length %></div>
                    <div class="stat-label">Content Linked (this page)</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">📤</div>
                <div>
                    <div class="stat-num"><%= notifications.reduce((s,n) => s + (n.sentCount||0), 0) %></div>
                    <div class="stat-label">Total Sent (this page)</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple">👁️</div>
                <div>
                    <div class="stat-num"><%= notifications.reduce((s,n) => s + (n.readCount||0), 0) %></div>
                    <div class="stat-label">Total Reads (this page)</div>
                </div>
            </div>
        </div>

        <!-- Filter chips -->
        <div class="filter-bar">
            <span class="filter-label">Filter by section:</span>
            <div class="filter-chips">
                <a href="/notifications" class="chip <%= !filterSection ? 'active' : '' %>">All</a>
                <a href="/notifications?section=kosh"             class="chip <%= filterSection==='kosh'             ? 'active':'' %>">📚 Kosh</a>
                <a href="/notifications?section=karmkand"         class="chip <%= filterSection==='karmkand'         ? 'active':'' %>">🪔 Karmkand</a>
                <a href="/notifications?section=book"             class="chip <%= filterSection==='book'             ? 'active':'' %>">📖 Book</a>
                <a href="/notifications?section=muhurat"          class="chip <%= filterSection==='muhurat'          ? 'active':'' %>">🌟 Muhurat</a>
                <a href="/notifications?section=rashifal_daily"   class="chip <%= filterSection==='rashifal_daily'   ? 'active':'' %>">♈ Rashifal</a>
                <a href="/notifications?section=numerology_daily" class="chip <%= filterSection==='numerology_daily' ? 'active':'' %>">🔢 Numerology</a>
                <a href="/notifications?section=festival"         class="chip <%= filterSection==='festival'         ? 'active':'' %>">🎉 Festival</a>
            </div>
        </div>

        <!-- Notification list -->
        <% if (notifications && notifications.length > 0) { %>
            <% notifications.forEach(function(n) {
                const hasDeepLink = n.deepLink && n.deepLink.contentType;
                const typeClass = n.type || 'info';
            %>
            <div class="notif-card">
                <div class="notif-card-inner">
                    <div class="notif-accent-bar <%= typeClass %>"></div>
                    <div class="notif-body">
                        <div class="notif-top">
                            <div class="notif-title"><%= n.title %></div>
                            <div style="display:flex;gap:.4rem;align-items:center;flex-wrap:wrap">
                                <span class="badge-pill badge-type <%= typeClass %>"><%= typeClass %></span>
                                <span class="badge-pill badge-priority <%= n.priority %>"><%= n.priority %></span>
                                <span class="badge-pill <%= n.isActive ? 'badge-active' : 'badge-inactive' %>">
                                    <%= n.isActive ? '● Active' : '○ Inactive' %>
                                </span>
                            </div>
                        </div>

                        <div class="notif-message"><%= n.message %></div>

                        <% if (hasDeepLink) { %>
                        <div class="deeplink-row">
                            <span class="deeplink-section-badge">
                                <%
                                    const sectionIcons = {
                                        kosh:'📚', karmkand:'🪔', book:'📖',
                                        muhurat:'🌟', rashifal_daily:'♈',
                                        numerology_daily:'🔢', festival:'🎉'
                                    };
                                %>
                                <%= sectionIcons[n.deepLink.contentType] || '🔗' %>
                                <%= n.deepLink.contentType.replace('_',' ') %>
                            </span>
                            <% if (n.deepLink.contentTitle) { %>
                                <span class="deeplink-title">→ "<%= n.deepLink.contentTitle %>"</span>
                            <% } %>
                            <% if (n.deepLink.categoryName) { %>
                                <span style="font-size:.75rem;color:#9CA3AF"><%= n.deepLink.categoryName %><% if(n.deepLink.subCategoryName){ %> › <%= n.deepLink.subCategoryName %><% } %></span>
                            <% } %>
                            <% if (n.deepLink.screen) { %>
                                <span style="font-size:.7rem;font-family:monospace;color:var(--orange);margin-left:auto">→ <%= n.deepLink.screen %></span>
                            <% } %>
                        </div>
                        <% if (n.deepLink.deepLinkUrl) { %>
                            <div class="deeplink-url" style="font-size:.72rem;font-family:monospace;color:#9CA3AF;margin-bottom:.5rem;padding-left:.25rem">
                                🔗 <%= n.deepLink.deepLinkUrl %>
                            </div>
                        <% } %>
                        <% } %>

                        <div class="notif-meta">
                            <div class="meta-dates">
                                <span>Created: <strong><%= new Date(n.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></strong></span>
                                <% if (n.scheduledAt) { %>
                                <span>Scheduled: <strong><%= new Date(n.scheduledAt).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %></strong></span>
                                <% } %>
                                <% if (n.expiresAt) { %>
                                <span>Expires: <strong style="color:#EF4444"><%= new Date(n.expiresAt).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %></strong></span>
                                <% } %>
                            </div>
                            <div class="analytics-row">
                                <span>📤 <span class="val"><%= n.sentCount||0 %></span> sent</span>
                                <span>👁 <span class="val"><%= n.readCount||0 %></span> read</span>
                                <span>🔗 <span class="val"><%= n.openCount||0 %></span> opens</span>
                            </div>
                        </div>

                        <div class="action-row" style="margin-top:.75rem">
                            <a href="/notifications/edit/<%= n._id %>" class="btn-action btn-edit">✏️ Edit</a>
                            <form action="/notifications/resend/<%= n._id %>" method="POST" class="d-inline">
                                <button type="submit" class="btn-action btn-resend">🚀 Resend</button>
                            </form>
                            <form action="/notifications/toggle/<%= n._id %>" method="POST" class="d-inline">
                                <button type="submit" class="btn-action btn-toggle">
                                    <%= n.isActive ? '⏸ Deactivate' : '▶ Activate' %>
                                </button>
                            </form>
                            <form action="/notifications/delete/<%= n._id %>" method="POST" class="d-inline"
                                  onsubmit="return confirm('Delete this notification?')">
                                <button type="submit" class="btn-action btn-del">🗑 Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
            <div class="pager">
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage-1 %><%= filterSection ? '&section='+filterSection : '' %>" class="page-btn">‹</a>
                <% } %>
                <% for (let i = Math.max(1, currentPage-2); i <= Math.min(totalPages, currentPage+2); i++) { %>
                    <a href="?page=<%= i %><%= filterSection ? '&section='+filterSection : '' %>"
                       class="page-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                <% } %>
                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage+1 %><%= filterSection ? '&section='+filterSection : '' %>" class="page-btn">›</a>
                <% } %>
            </div>
            <% } %>

        <% } else { %>
            <div style="background:white;border-radius:16px;box-shadow:var(--card-shadow)">
                <div class="empty-state">
                    <div class="big-icon">🔔</div>
                    <h3 style="font-family:'Playfair Display',serif;color:var(--dark)">No notifications yet</h3>
                    <p style="color:#9CA3AF;margin-bottom:1.5rem">Create your first content-linked notification to engage users</p>
                    <a href="/notifications/add" class="add-btn">＋ Send First Notification</a>
                </div>
            </div>
        <% } %>
    </main>

    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
